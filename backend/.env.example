# Copy to .env and fill in values. Never commit .env.

# AI Builder Space
AI_BUILDER_BASE_URL=
AI_BUILDER_TOKEN=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-side secrets (generate secure random strings)
# Hash client IPs for abuse control and rate limiting
HMAC_SECRET=
# Fingerprint requests for cache deduplication
FINGERPRINT_SECRET=
# Admin: required to access GET /api/admin/analytics
ADMIN_KEY=

