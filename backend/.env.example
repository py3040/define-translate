# Copy to .env and fill in values. Never commit .env.

# AI Builder Space (use https://space.ai-builders.com/backend for SDK)
AI_BUILDER_BASE_URL=https://space.ai-builders.com/backend
AI_BUILDER_TOKEN=
# AI_BUILDER_TIMEOUT_SEC=60  # Optional, default 60s (increase if AI service is slow)

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-side secrets (generate secure random strings)
HMAC_SECRET=
FINGERPRINT_SECRET=

# Admin: required to access GET /api/admin/analytics. If unset, that endpoint
# is locked (503). Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=

# Optional: enables GET /api/_debug/ip for the IP-forwarding test. Leave unset
# in normal operation (endpoint returns 404). Generate the same way as ADMIN_KEY.
IP_DEBUG_TOKEN=

# Optional: number of trusted proxies that append to X-Forwarded-For before the
# request reaches this app. The real client IP is taken this many positions from
# the right of the XFF chain (spoof-resistant). Default 2 (platform proxy +
# Cloudflare on AI Builder Space). Only change if /api/_debug/ip shows a
# different trusted hop count.
# TRUSTED_PROXY_HOPS=2
